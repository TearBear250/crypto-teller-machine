{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/TearBear250/crypto-teller-machine/shared/schemas/audit-event.json",
  "title": "AuditEvent",
  "description": "Immutable audit log entry for a hardware or software event at the kiosk",
  "type": "object",
  "required": [
    "event_id",
    "kiosk_id",
    "event_type",
    "occurred_at"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for this event (generated by kiosk)"
    },
    "kiosk_id": {
      "type": "string",
      "description": "Identifier of the kiosk that generated the event"
    },
    "session_id": {
      "type": ["string", "null"],
      "format": "uuid",
      "description": "Session this event belongs to (null for non-session events)"
    },
    "transaction_id": {
      "type": ["string", "null"],
      "format": "uuid",
      "description": "Transaction this event belongs to (null if not yet created)"
    },
    "event_type": {
      "type": "string",
      "enum": [
        "BILL_INSERTED",
        "BILL_REJECTED",
        "CASH_DISPENSED",
        "QR_SCANNED",
        "SESSION_CREATED",
        "SESSION_CONFIRMED",
        "SESSION_CANCELLED",
        "SESSION_COMPLETED",
        "TX_BROADCAST",
        "TX_CONFIRMED",
        "TX_FAILED",
        "HAL_ERROR",
        "DEVICE_RECONNECTED",
        "OPERATOR_LOGIN",
        "OPERATOR_LOGOUT",
        "CONFIG_UPDATED",
        "CERT_ROTATION",
        "POLICY_CHANGE",
        "TAMPER_ALERT"
      ]
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time",
      "description": "Wall-clock time at the kiosk when the event occurred (UTC)"
    },
    "metadata": {
      "type": "object",
      "description": "Event-specific supplementary data. Must not include PII or private keys.",
      "additionalProperties": true,
      "examples": [
        {
          "denomination": 20,
          "currency": "CAD",
          "bill_count": 1
        },
        {
          "asset_id": "ltc",
          "txid": "abc123...",
          "confirmations": 2
        }
      ]
    }
  },
  "additionalProperties": false
}
