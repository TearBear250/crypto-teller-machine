{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/TearBear250/crypto-teller-machine/shared/schemas/session.json",
  "title": "Session",
  "description": "A user interaction session at the kiosk (wraps one transaction)",
  "type": "object",
  "required": [
    "session_id",
    "kiosk_id",
    "direction",
    "asset_id",
    "fiat_currency",
    "state",
    "created_at"
  ],
  "properties": {
    "session_id": {
      "type": "string",
      "format": "uuid"
    },
    "kiosk_id": {
      "type": "string"
    },
    "direction": {
      "type": "string",
      "enum": ["buy", "sell"]
    },
    "asset_id": {
      "type": "string",
      "enum": ["ltc", "doge", "xrp", "sol"]
    },
    "network_mode": {
      "type": "string",
      "enum": ["testnet", "mainnet"]
    },
    "quote_id": {
      "type": ["string", "null"],
      "format": "uuid"
    },
    "fiat_amount": {
      "type": ["number", "null"],
      "format": "double",
      "minimum": 0,
      "exclusiveMinimum": true
    },
    "fiat_currency": {
      "type": "string",
      "minLength": 3,
      "maxLength": 3
    },
    "asset_amount": {
      "type": ["number", "null"],
      "format": "double",
      "minimum": 0,
      "exclusiveMinimum": true
    },
    "destination_address": {
      "type": ["string", "null"]
    },
    "destination_tag": {
      "type": ["integer", "null"]
    },
    "transaction_id": {
      "type": ["string", "null"],
      "format": "uuid"
    },
    "state": {
      "type": "string",
      "enum": [
        "AWAITING_CASH",
        "AWAITING_CRYPTO",
        "PROCESSING",
        "CONFIRMING",
        "CONFIRMED",
        "DISPENSING",
        "COMPLETE",
        "CANCELLED",
        "FAILED"
      ]
    },
    "timeout_at": {
      "type": ["string", "null"],
      "format": "date-time",
      "description": "Session expiry deadline"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "completed_at": {
      "type": ["string", "null"],
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
